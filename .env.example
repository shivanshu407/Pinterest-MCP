# Canonical public production URL, without a trailing slash.
# After the first Vercel deploy, set this to the final stable domain and redeploy.
APP_URL=https://your-project.vercel.app

# Create a Pinterest developer app and register this exact callback URL:
# https://your-project.vercel.app/oauth/pinterest/callback
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Set true only when secret-board access is genuinely required and approved.
# Adds boards:read_secret and pins:read_secret to the default read-only scopes.
PINTEREST_INCLUDE_SECRET_SCOPES=false

# Upstash Redis / Vercel Marketplace Redis credentials.
# KV_REST_API_URL and KV_REST_API_TOKEN are also accepted as fallbacks.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Exactly 32 random bytes, base64 encoded.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Public-facing legal and support information used by /privacy and /terms.
# Replace placeholders before Pinterest review or public launch.
LEGAL_ENTITY_NAME=Your Company Legal Name
SUPPORT_EMAIL=support@your-domain.com
